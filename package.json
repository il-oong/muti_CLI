{
  "name": "muti-cli",
  "version": "0.1.0",
  "description": "Multi-CLI desktop terminal — M3 tabs + xterm + node-pty",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.0.9"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "build": {
    "appId": "com.muticli.app",
    "productName": "Muti CLI",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/xterm/**/*",
      "node_modules/xterm-addon-fit/**/*"
    ]
  }
}
