{
  "name": "muti-cli",
  "version": "0.1.0",
  "description": "Multi-CLI desktop terminal — project-based tab groups with autosave",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "build": {
    "appId": "com.muticli.app",
    "productName": "Muti CLI",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/xterm/**/*",
      "node_modules/xterm-addon-fit/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "artifactName": "MutiCLI-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Muti CLI"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    }
  }
}
